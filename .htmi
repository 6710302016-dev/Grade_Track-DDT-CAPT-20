import React, { useState, useEffect } from 'react';
import { 
  GraduationCap, 
  BookOpen, 
  Plus, 
  Trash2, 
  Edit3, 
  TrendingUp, 
  CheckCircle, 
  AlertCircle, 
  Settings, 
  Layout, 
  User, 
  ChevronRight, 
  ChevronDown, 
  Info, 
  PlusCircle, 
  X,
  Palette,
  Volume2,
  FileText,
  Search,
  Sliders,
  Sparkles
} from 'lucide-react';

// --- INITIAL DIGITAL DESIGN & TECH CURRICULUM TEMPLATE ---
// Pre-populated data representing a Digital Design & Technology student's actual pathway
const INITIAL_COURSES = [
  // Semester 1/1
  { id: '1', code: 'GE-101', name: 'ทักษะภาษาไทยเพื่อการสื่อสารดิจิทัล', credits: 3, grade: 'A', category: 'GE-Thai', term: '1/1' },
  { id: '2', code: 'GE-112', name: 'ภาษาอังกฤษเพื่อการสื่อสารสากล', credits: 3, grade: 'B+', category: 'GE-English', term: '1/1' },
  { id: '3', code: 'GE-121', name: 'นวัตกรรมและเทคโนโลยีสีเขียว', credits: 3, grade: 'A', category: 'GE-Sci', term: '1/1' },
  { id: '4', code: 'DDT-101', name: 'ประวัติศาสตร์และการออกแบบดิจิทัล', credits: 3, grade: 'A', category: 'Core', term: '1/1' },
  { id: '5', code: 'DDT-102', name: 'องค์ประกอบศิลป์สำหรับสื่อดิจิทัล', credits: 3, grade: 'B', category: 'Core', term: '1/1' },
  
  // Semester 1/2
  { id: '6', code: 'GE-131', name: 'คณิตศาสตร์สำหรับคอมพิวเตอร์กราฟิก', credits: 3, grade: 'A', category: 'GE-Math', term: '1/2' },
  { id: '7', code: 'GE-142', name: 'จิตวิทยาสังคมในยุคดิจิทัล', credits: 3, grade: 'B+', category: 'GE-Social', term: '1/2' },
  { id: '8', code: 'DDT-103', name: 'การคิดเชิงออกแบบและการสื่อสารแบรนด์', credits: 3, grade: 'A', category: 'Core', term: '1/2' },
  { id: '9', code: 'DDT-104', name: 'หลักการโปรแกรมมิ่งสร้างสรรค์ (Creative Coding)', credits: 3, grade: 'C+', category: 'Core', term: '1/2' },
  
  // Semester 2/1
  { id: '10', code: 'GE-151', name: 'สุนทรียศาสตร์และการคิดสร้างสรรค์', credits: 3, grade: 'A', category: 'GE-Human', term: '2/1' },
  { id: '11', code: 'DDT-201', name: 'การออกแบบประสบการณ์ผู้ใช้ (UI/UX Design)', credits: 3, grade: 'A', category: 'Major-Compulsory', term: '2/1' },
  { id: '12', code: 'DDT-202', name: 'การสร้างแบบจำลอง 3 มิติเชิงดิจิทัล (3D Modeling)', credits: 3, grade: 'B', category: 'Major-Compulsory', term: '2/1' },
  { id: '13', code: 'DDT-203', name: 'การพัฒนาเว็บเทคโนโลยีขั้นสูง', credits: 3, grade: 'A', category: 'Major-Compulsory', term: '2/1' },
  
  // Semester 2/2
  { id: '14', code: 'DDT-204', name: 'แอนิเมชันและการออกแบบเคลื่อนไหว (Motion Design)', credits: 3, grade: 'A', category: 'Major-Compulsory', term: '2/2' },
  { id: '15', code: 'DDT-205', name: 'การออกแบบเกมและปฏิสัมพันธ์ (Interaction Design)', credits: 3, grade: 'B+', category: 'Major-Compulsory', term: '2/2' },
  { id: '16', code: 'DDT-E01', name: 'ศิลปะสร้างสรรค์ด้วยปัญญาประดิษฐ์ (AI Creative Tools)', credits: 3, grade: 'A', category: 'Major-Elective', term: '2/2' },
];

// Master curriculum database of required major compulsory courses to track "What's missing"
const MAJOR_COMPULSORY_REQUIREMENTS = [
  { code: 'DDT-201', name: 'การออกแบบประสบการณ์ผู้ใช้ (UI/UX Design)', credits: 3 },
  { code: 'DDT-202', name: 'การสร้างแบบจำลอง 3 มิติเชิงดิจิทัล (3D Modeling)', credits: 3 },
  { code: 'DDT-203', name: 'การพัฒนาเว็บเทคโนโลยีขั้นสูง', credits: 3 },
  { code: 'DDT-204', name: 'แอนิเมชันและการออกแบบเคลื่อนไหว (Motion Design)', credits: 3 },
  { code: 'DDT-205', name: 'การออกแบบเกมและปฏิสัมพันธ์ (Interaction Design)', credits: 3 },
  { code: 'DDT-301', name: 'การออกแบบสื่อและเนื้อหาดิจิทัลขั้นสูง', credits: 3 },
  { code: 'DDT-302', name: 'การออกแบบสภาพแวดล้อมเสมือนจริง (VR/AR Design)', credits: 3 },
  { code: 'DDT-303', name: 'การจัดการโครงการออกแบบและทรัพย์สินทางปัญญา', credits: 3 },
  { code: 'DDT-304', name: 'เตรียมฝึกงานและทักษะวิชาชีพ', credits: 1 },
  { code: 'DDT-401', name: 'โครงงานออกแบบดิจิทัลและเทคโนโลยี 1 (Capstone Project I)', credits: 3 },
  { code: 'DDT-402', name: 'โครงงานออกแบบดิจิทัลและเทคโนโลยี 2 (Capstone Project II)', credits: 3 },
  { code: 'DDT-403', name: 'ฝึกปฏิบัติงานวิชาชีพออกแบบดิจิทัล (Internship)', credits: 6 },
];

const GRADE_POINTS = {
  'A': 4.0, 'B+': 3.5, 'B': 3.0, 'C+': 2.5, 'C': 2.0, 'D+': 1.5, 'D': 1.0, 'F': 0.0, 'W': null
};

export default function App() {
  const [courses, setCourses] = useState(() => {
    const saved = localStorage.getItem('ddt_courses');
    return saved ? JSON.parse(saved) : INITIAL_COURSES;
  });

  useEffect(() => {
    localStorage.setItem('ddt_courses', JSON.stringify(courses));
  }, [courses]);

  // UI States
  const [activeTab, setActiveTab] = useState('dashboard'); // dashboard, planner, curriculum, designSystem
  const [isMobileFrame, setIsMobileFrame] = useState(true);
  const [selectedTermFilter, setSelectedTermFilter] = useState('All');
  
  // Profile settings
  const [profile, setProfile] = useState({
    name: 'ณัฐพงษ์ ศรีสุขดี',
    studentId: '66010916024',
    major: 'การออกแบบดิจิทัลและเทคโนโลยี (DD&T)',
    year: 'ปีที่ 2',
    avatar: 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&q=80&w=256'
  });

  // Dialog State
  const [isAddOpen, setIsAddOpen] = useState(false);
  const [editingCourse, setEditingCourse] = useState(null);
  const [newCourse, setNewCourse] = useState({
    code: '',
    name: '',
    credits: 3,
    grade: 'A',
    category: 'Major-Compulsory',
    term: '2/1'
  });

  // Calculations
  const calculateGPAStats = () => {
    let totalPoints = 0;
    let totalGPAXCredits = 0;
    let totalEarnedCredits = 0;
    let hasF = false;

    // Credit tracking per category
    const categoryCredits = {
      'GE-Thai': 0, 'GE-English': 0, 'GE-Sci': 0, 'GE-Math': 0, 'GE-Social': 0, 'GE-Human': 0,
      'Core': 0, 'Major-Compulsory': 0, 'Major-Elective': 0, 'Free-Elective': 0
    };

    courses.forEach(c => {
      const p = GRADE_POINTS[c.grade];
      const cred = Number(c.credits);
      
      if (c.grade === 'F') {
        hasF = true;
      }

      if (p !== null && c.grade !== 'W') {
        totalPoints += p * cred;
        totalGPAXCredits += cred;
      }
      
      if (c.grade !== 'F' && c.grade !== 'W') {
        totalEarnedCredits += cred;
        categoryCredits[c.category] = (categoryCredits[c.category] || 0) + cred;
      }
    });

    const gpax = totalGPAXCredits > 0 ? (totalPoints / totalGPAXCredits).toFixed(2) : '0.00';

    // Honor Predictions
    let honors = 'ไม่มี';
    if (Number(gpax) >= 3.75 && !hasF) {
      honors = 'เกียรตินิยมอันดับ 1';
    } else if (Number(gpax) >= 3.25 && Number(gpax) < 3.75 && !hasF) {
      honors = 'เกียรตินิยมอันดับ 2';
    }

    // Category Requirements Matcher
    const geThaiEarned = categoryCredits['GE-Thai'];
    const geEngEarned = categoryCredits['GE-English'];
    const geSciEarned = categoryCredits['GE-Sci'];
    const geMathEarned = categoryCredits['GE-Math'];
    const geSocEarned = categoryCredits['GE-Social'];
    const geHumEarned = categoryCredits['GE-Human'];
    
    const geTotalEarned = geThaiEarned + geEngEarned + geSciEarned + geMathEarned + geSocEarned + geHumEarned;
    const coreEarned = categoryCredits['Core'];
    const majorCompEarned = categoryCredits['Major-Compulsory'];
    const majorEleEarned = categoryCredits['Major-Elective'];
    const freeEarned = categoryCredits['Free-Elective'];

    return {
      gpax,
      totalEarnedCredits,
      totalGPAXCredits,
      hasF,
      honors,
      categoryCredits,
      summary: {
        ge: { earned: geTotalEarned, required: 33 },
        core: { earned: coreEarned, required: 27 },
        majorComp: { earned: majorCompEarned, required: 52 },
        majorEle: { earned: majorEleEarned, required: 15 },
        free: { earned: freeEarned, required: 6 },
        total: { earned: totalEarnedCredits, required: 133 }
      }
    };
  };

  const stats = calculateGPAStats();

  // Handle Add/Edit Course
  const handleSaveCourse = (e) => {
    e.preventDefault();
    if (!newCourse.code || !newCourse.name) return;

    if (editingCourse) {
      setCourses(courses.map(c => c.id === editingCourse.id ? { ...newCourse, id: c.id } : c));
      setEditingCourse(null);
    } else {
      setCourses([...courses, { ...newCourse, id: Date.now().toString() }]);
    }
    setNewCourse({ code: '', name: '', credits: 3, grade: 'A', category: 'Major-Compulsory', term: '2/1' });
    setIsAddOpen(false);
  };

  const handleEditClick = (course) => {
    setEditingCourse(course);
    setNewCourse(course);
    setIsAddOpen(true);
  };

  const handleDeleteCourse = (id) => {
    setCourses(courses.filter(c => c.id !== id));
  };

  // Grouped Courses by Term for Grade Planner
  const terms = ['1/1', '1/2', '2/1', '2/2', '3/1', '3/2', '4/1', '4/2'];
  const getCoursesByTerm = (term) => courses.filter(c => c.term === term);

  const calculateTermGPA = (term) => {
    const termCourses = getCoursesByTerm(term);
    let totalPoints = 0;
    let totalCredits = 0;
    termCourses.forEach(c => {
      const p = GRADE_POINTS[c.grade];
      if (p !== null && c.grade !== 'W') {
        totalPoints += p * Number(c.credits);
        totalCredits += Number(c.credits);
      }
    });
    return totalCredits > 0 ? (totalPoints / totalCredits).toFixed(2) : '0.00';
  };

  // Content render helper
  const renderAppContent = () => {
    switch(activeTab) {
      case 'dashboard':
        return (
          <div className="space-y-5 animate-fade-in">
            {/* Top Stat Summary Header */}
            <div className="bg-gradient-to-r from-emerald-600 to-teal-700 rounded-3xl p-5 text-white shadow-xl relative overflow-hidden">
              <div className="absolute right-[-20px] bottom-[-20px] opacity-10">
                <GraduationCap size={150} />
              </div>
              <div className="flex justify-between items-start">
                <div>
                  <p className="text-emerald-100 text-xs tracking-wider uppercase font-medium">เกรดเฉลี่ยสะสม (GPAX)</p>
                  <h1 className="text-5xl font-extrabold tracking-tight mt-1" style={{ fontFamily: 'Inter' }}>
                    {stats.gpax}
                  </h1>
                </div>
                <div className="bg-white/15 backdrop-blur-md px-3 py-1.5 rounded-full text-xs font-semibold flex items-center gap-1.5">
                  <span className="w-2 h-2 rounded-full bg-emerald-300 animate-pulse"></span>
                  สถานะ: ลงทะเบียนแล้ว {stats.totalEarnedCredits}/133 นก.
                </div>
              </div>

              {/* Predict Honors Badge */}
              <div className="mt-5 pt-4 border-t border-white/10 flex justify-between items-center text-sm">
                <div className="flex items-center gap-2">
                  <Sparkles size={16} className="text-emerald-300" />
                  <span>เกียรตินิยมคาดการณ์:</span>
                </div>
                <span className={`font-bold px-3 py-1 rounded-full text-xs ${
                  stats.honors.includes('1') ? 'bg-amber-400 text-slate-900 shadow' : 
                  stats.honors.includes('2') ? 'bg-slate-200 text-slate-800' : 'bg-white/10'
                }`}>
                  {stats.honors}
                </span>
              </div>
            </div>

            {/* Quick Stat Grid */}
            <div className="grid grid-cols-2 gap-3">
              <div className="bg-white p-4 rounded-2xl border border-slate-100 shadow-sm flex flex-col justify-between">
                <span className="text-xs text-slate-500 font-medium">หน่วยกิตคงเหลือหลักสูตร</span>
                <div className="mt-2 flex items-baseline gap-1">
                  <span className="text-2xl font-bold text-slate-800">{Math.max(0, 133 - stats.totalEarnedCredits)}</span>
                  <span className="text-xs text-slate-400">หน่วยกิต</span>
                </div>
                <div className="w-full bg-slate-100 h-1.5 rounded-full mt-3 overflow-hidden">
                  <div 
                    className="bg-emerald-500 h-full rounded-full transition-all duration-500"
                    style={{ width: `${Math.min(100, (stats.totalEarnedCredits / 133) * 100)}%` }}
                  ></div>
                </div>
              </div>

              <div className="bg-white p-4 rounded-2xl border border-slate-100 shadow-sm flex flex-col justify-between">
                <span className="text-xs text-slate-500 font-medium">ประวัติเกรด F</span>
                <div className="mt-2 flex items-center gap-2">
                  {stats.hasF ? (
                    <>
                      <AlertCircle className="text-rose-500" size={20} />
                      <span className="text-sm font-bold text-rose-600">เคยได้รับ (งดเกียรตินิยม)</span>
                    </>
                  ) : (
                    <>
                      <CheckCircle className="text-emerald-500" size={20} />
                      <span className="text-sm font-bold text-emerald-600">ปกติ (ไม่มีประวัติ)</span>
                    </>
                  )}
                </div>
                <p className="text-[10px] text-slate-400 mt-3">*ห้ามมีเกรด F ตลอดหลักสูตร</p>
              </div>
            </div>

            {/* Credit Progress breakdown */}
            <div className="bg-white p-5 rounded-3xl border border-slate-100 shadow-sm">
              <h3 className="text-sm font-bold text-slate-800 mb-4 flex items-center gap-2">
                <Sliders size={16} className="text-teal-600" />
                ความคืบหน้าตามหมวดหลักสูตร (133 นก.)
              </h3>
              
              <div className="space-y-4">
                {/* GE */}
                <div>
                  <div className="flex justify-between text-xs text-slate-600 mb-1">
                    <span>1. หมวดศึกษาทั่วไป (GE)</span>
                    <span className="font-semibold">{stats.summary.ge.earned} / {stats.summary.ge.required} นก.</span>
                  </div>
                  <div className="w-full bg-slate-100 h-2 rounded-full overflow-hidden">
                    <div 
                      className="bg-teal-500 h-full rounded-full" 
                      style={{ width: `${Math.min(100, (stats.summary.ge.earned / stats.summary.ge.required) * 100)}%` }}
                    ></div>
                  </div>
                  <div className="grid grid-cols-6 gap-1 mt-1 text-[9px] text-slate-400">
                    <span className={stats.categoryCredits['GE-Thai'] >= 3 ? 'text-emerald-600 font-medium' : ''}>ไทย ({stats.categoryCredits['GE-Thai']}/3)</span>
                    <span className={stats.categoryCredits['GE-English'] >= 6 ? 'text-emerald-600 font-medium' : ''}>ตปท. ({stats.categoryCredits['GE-English']}/6)</span>
                    <span className={stats.categoryCredits['GE-Sci'] >= 3 ? 'text-emerald-600 font-medium' : ''}>วิทย์ ({stats.categoryCredits['GE-Sci']}/3)</span>
                    <span className={stats.categoryCredits['GE-Math'] >= 3 ? 'text-emerald-600 font-medium' : ''}>คณิต ({stats.categoryCredits['GE-Math']}/3)</span>
                    <span className={stats.categoryCredits['GE-Social'] >= 3 ? 'text-emerald-600 font-medium' : ''}>สังคม ({stats.categoryCredits['GE-Social']}/3)</span>
                    <span className={stats.categoryCredits['GE-Human'] >= 3 ? 'text-emerald-600 font-medium' : ''}>มนุษย์ ({stats.categoryCredits['GE-Human']}/3)</span>
                  </div>
                </div>

                {/* Core */}
                <div>
                  <div className="flex justify-between text-xs text-slate-600 mb-1">
                    <span>2. หมวดวิชาแกนหลักสาขา</span>
                    <span className="font-semibold">{stats.summary.core.earned} / {stats.summary.core.required} นก.</span>
                  </div>
                  <div className="w-full bg-slate-100 h-2 rounded-full overflow-hidden">
                    <div 
                      className="bg-indigo-500 h-full rounded-full" 
                      style={{ width: `${Math.min(100, (stats.summary.core.earned / stats.summary.core.required) * 100)}%` }}
                    ></div>
                  </div>
                </div>

                {/* Major Compulsory */}
                <div>
                  <div className="flex justify-between text-xs text-slate-600 mb-1">
                    <span>3. หมวดวิชาชีพบังคับ (Compulsory)</span>
                    <span className="font-semibold text-emerald-600">{stats.summary.majorComp.earned} / {stats.summary.majorComp.required} นก.</span>
                  </div>
                  <div className="w-full bg-slate-100 h-2 rounded-full overflow-hidden">
                    <div 
                      className="bg-emerald-500 h-full rounded-full" 
                      style={{ width: `${Math.min(100, (stats.summary.majorComp.earned / stats.summary.majorComp.required) * 100)}%` }}
                    ></div>
                  </div>
                </div>

                {/* Major Elective */}
                <div>
                  <div className="flex justify-between text-xs text-slate-600 mb-1">
                    <span>4. หมวดวิชาชีพเลือก (Elective)</span>
                    <span className="font-semibold">{stats.summary.majorEle.earned} / {stats.summary.majorEle.required} นก.</span>
                  </div>
                  <div className="w-full bg-slate-100 h-2 rounded-full overflow-hidden">
                    <div 
                      className="bg-amber-500 h-full rounded-full" 
                      style={{ width: `${Math.min(100, (stats.summary.majorEle.earned / stats.summary.majorEle.required) * 100)}%` }}
                    ></div>
                  </div>
                </div>

                {/* Free Elective */}
                <div>
                  <div className="flex justify-between text-xs text-slate-600 mb-1">
                    <span>5. หมวดวิชาเลือกเสรี</span>
                    <span className="font-semibold">{stats.summary.free.earned} / {stats.summary.free.required} นก.</span>
                  </div>
                  <div className="w-full bg-slate-100 h-2 rounded-full overflow-hidden">
                    <div 
                      className="bg-slate-400 h-full rounded-full" 
                      style={{ width: `${Math.min(100, (stats.summary.free.earned / stats.summary.free.required) * 100)}%` }}
                    ></div>
                  </div>
                </div>
              </div>
            </div>

            {/* GPA Chart section */}
            <div className="bg-white p-5 rounded-3xl border border-slate-100 shadow-sm">
              <div className="flex justify-between items-center mb-4">
                <h3 className="text-sm font-bold text-slate-800 flex items-center gap-2">
                  <TrendingUp size={16} className="text-emerald-500" />
                  เส้นทางผลการเรียนรายภาค (GPA Track)
                </h3>
                <span className="text-xs text-emerald-600 font-bold bg-emerald-50 px-2 py-0.5 rounded-full">DD&T Major</span>
              </div>
              
              {/* Draw beautiful SVG Line chart for terms 1/1 to 2/2 */}
              <div className="relative pt-2">
                <svg className="w-full h-32" viewBox="0 0 400 120">
                  {/* Grid Lines */}
                  <line x1="10" y1="20" x2="390" y2="20" stroke="#f1f5f9" strokeWidth="1" />
                  <line x1="10" y1="50" x2="390" y2="50" stroke="#f1f5f9" strokeWidth="1" />
                  <line x1="10" y1="80" x2="390" y2="80" stroke="#f1f5f9" strokeWidth="1" />
                  <line x1="10" y1="110" x2="390" y2="110" stroke="#f1f5f9" strokeWidth="1" />
                  
                  {/* Values mapped onto the SVG coordinate */}
                  {/* GPA: 4.0 -> y:20, 3.0 -> y:50, 2.0 -> y:80, 1.0 -> y:110 */}
                  {/* Points: 1/1 (x: 50), 1/2 (x: 130), 2/1 (x: 210), 2/2 (x: 290) */}
                  <path
                    d={`M 50 ${110 - (calculateTermGPA('1/1') - 1) * 30} 
                       L 130 ${110 - (calculateTermGPA('1/2') - 1) * 30} 
                       L 210 ${110 - (calculateTermGPA('2/1') - 1) * 30} 
                       L 290 ${110 - (calculateTermGPA('2/2') - 1) * 30}`}
                    fill="none"
                    stroke="url(#gradient)"
                    strokeWidth="4"
                    strokeLinecap="round"
                    strokeLinejoin="round"
                  />
                  
                  {/* Gradients definition */}
                  <defs>
                    <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="0%">
                      <stop offset="0%" stopColor="#10b981" />
                      <stop offset="100%" stopColor="#0d9488" />
                    </linearGradient>
                  </defs>

                  {/* Nodes & Labels */}
                  {[
                    { term: '1/1', x: 50 },
                    { term: '1/2', x: 130 },
                    { term: '2/1', x: 210 },
                    { term: '2/2', x: 290 },
                  ].map((pt, idx) => {
                    const termGpa = calculateTermGPA(pt.term);
                    const y = 110 - (termGpa - 1) * 30;
                    return (
                      <g key={idx}>
                        <circle cx={pt.x} cy={y} r="5" fill="#ffffff" stroke="#10b981" strokeWidth="3" />
                        <text x={pt.x} y={y - 12} textAnchor="middle" fontSize="10" fontWeight="bold" fill="#0f172a">
                          {termGpa}
                        </text>
                        <text x={pt.x} y="118" textAnchor="middle" fontSize="8" fill="#64748b" fontWeight="medium">
                          เทอม {pt.term}
                        </text>
                      </g>
                    );
                  })}
                </svg>
              </div>
            </div>
          </div>
        );

      case 'planner':
        return (
          <div className="space-y-4 animate-fade-in">
            <div className="flex justify-between items-center">
              <h2 className="text-lg font-bold text-slate-800 flex items-center gap-2">
                <BookOpen className="text-emerald-500" size={20} />
                เกรดและรายวิชาแต่ละเทอม
              </h2>
              <button 
                onClick={() => {
                  setEditingCourse(null);
                  setNewCourse({ code: '', name: '', credits: 3, grade: 'A', category: 'Major-Compulsory', term: '2/1' });
                  setIsAddOpen(true);
                }}
                className="bg-emerald-600 hover:bg-emerald-700 text-white text-xs px-3 py-2 rounded-full flex items-center gap-1 font-semibold transition"
              >
                <Plus size={14} />
                เพิ่มวิชาเรียน
              </button>
            </div>

            {/* Term Selectors & Course lists */}
            <div className="space-y-3">
              {terms.map(term => {
                const termCourses = getCoursesByTerm(term);
                const termGpa = calculateTermGPA(term);
                
                return (
                  <div key={term} className="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
                    <div className="bg-slate-50/80 px-4 py-3 flex justify-between items-center border-b border-slate-100">
                      <div>
                        <span className="text-xs text-slate-400 font-medium">ภาคการศึกษา</span>
                        <h4 className="text-sm font-bold text-slate-700">เทอม {term}</h4>
                      </div>
                      <div className="text-right">
                        <span className="text-[10px] text-slate-400 block">GPA ประจำเทอม</span>
                        <span className="text-sm font-extrabold text-teal-600">{termGpa}</span>
                      </div>
                    </div>

                    <div className="p-2 divide-y divide-slate-50">
                      {termCourses.length === 0 ? (
                        <p className="text-xs text-slate-400 text-center py-4">ยังไม่มีรายวิชาลงทะเบียนในเทอมนี้</p>
                      ) : (
                        termCourses.map(course => (
                          <div key={course.id} className="p-2 flex justify-between items-center gap-2">
                            <div className="flex-1 min-w-0">
                              <div className="flex items-center gap-1.5 mb-1">
                                <span className="text-[10px] font-mono bg-slate-100 text-slate-600 px-1.5 py-0.5 rounded">
                                  {course.code}
                                </span>
                                <span className={`text-[9px] font-medium px-1.5 py-0.5 rounded-full ${
                                  course.category.includes('Compulsory') ? 'bg-emerald-50 text-emerald-700' :
                                  course.category.includes('Elective') ? 'bg-amber-50 text-amber-700' :
                                  course.category.includes('Core') ? 'bg-indigo-50 text-indigo-700' :
                                  'bg-slate-100 text-slate-600'
                                }`}>
                                  {course.category}
                                </span>
                              </div>
                              <p className="text-xs font-bold text-slate-700 truncate">{course.name}</p>
                              <p className="text-[10px] text-slate-400">{course.credits} หน่วยกิต</p>
                            </div>

                            <div className="flex items-center gap-3">
                              <span className={`w-8 h-8 rounded-full flex items-center justify-center font-bold text-xs ${
                                course.grade.includes('A') || course.grade.includes('B') ? 'bg-emerald-50 text-emerald-600' :
                                course.grade.includes('C') ? 'bg-amber-50 text-amber-600' : 'bg-rose-50 text-rose-600'
                              }`}>
                                {course.grade}
                              </span>
                              <div className="flex gap-1">
                                <button 
                                  onClick={() => handleEditClick(course)}
                                  className="p-1 text-slate-400 hover:text-emerald-600 transition"
                                >
                                  <Edit3 size={14} />
                                </button>
                                <button 
                                  onClick={() => handleDeleteCourse(course.id)}
                                  className="p-1 text-slate-400 hover:text-rose-600 transition"
                                >
                                  <Trash2 size={14} />
                                </button>
                              </div>
                            </div>
                          </div>
                        ))
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        );

      case 'curriculum':
        return (
          <div className="space-y-4 animate-fade-in">
            <div className="bg-emerald-50 p-4 rounded-3xl border border-emerald-100/50">
              <h3 className="text-sm font-bold text-emerald-900 flex items-center gap-1.5 mb-1">
                <Info size={16} />
                ตรวจสอบวิชาบังคับสาขาดิจิทัลดีไซน์
              </h3>
              <p className="text-xs text-emerald-700 leading-relaxed">
                หลักสูตรกำหนดให้นักศึกษาต้องผ่าน **วิชาชีพบังคับจำนวน 52 หน่วยกิต** และ **วิชาชีพเลือก 15 หน่วยกิต** ด้านล่างนี้คือรายการเพื่อตรวจสอบวิชาบังคับที่ขาดอยู่
              </p>
            </div>

            {/* Checklist of Major Compulsory Courses */}
            <div className="bg-white p-5 rounded-3xl border border-slate-100 shadow-sm">
              <h3 className="text-sm font-bold text-slate-800 mb-4 flex items-center gap-2">
                <CheckCircle size={18} className="text-emerald-500" />
                สถานะรายวิชาชีพบังคับ (Compulsory)
              </h3>

              <div className="space-y-3">
                {MAJOR_COMPULSORY_REQUIREMENTS.map((req, idx) => {
                  const matchedCourse = courses.find(c => c.code.toLowerCase() === req.code.toLowerCase());
                  const isCompleted = matchedCourse && matchedCourse.grade !== 'F' && matchedCourse.grade !== 'W';
                  
                  return (
                    <div 
                      key={idx} 
                      className={`p-3 rounded-2xl border transition flex justify-between items-center ${
                        isCompleted ? 'bg-emerald-50/50 border-emerald-100' : 'bg-slate-50/50 border-slate-100'
                      }`}
                    >
                      <div className="flex-1 min-w-0 pr-2">
                        <div className="flex items-center gap-2 mb-1">
                          <span className="font-mono text-[9px] font-semibold bg-slate-200 text-slate-700 px-1.5 py-0.5 rounded">
                            {req.code}
                          </span>
                          <span className="text-[10px] text-slate-400">{req.credits} หน่วยกิต</span>
                        </div>
                        <p className="text-xs font-bold text-slate-700 truncate">{req.name}</p>
                      </div>

                      <div>
                        {isCompleted ? (
                          <div className="flex items-center gap-1 text-emerald-600 bg-white border border-emerald-100 px-2 py-1 rounded-full text-[10px] font-bold">
                            <CheckCircle size={12} />
                            ผ่านแล้ว ({matchedCourse.grade})
                          </div>
                        ) : (
                          <button
                            onClick={() => {
                              setNewCourse({
                                code: req.code,
                                name: req.name,
                                credits: req.credits,
                                grade: 'A',
                                category: 'Major-Compulsory',
                                term: '2/2'
                              });
                              setIsAddOpen(true);
                            }}
                            className="flex items-center gap-1 text-indigo-600 bg-white border border-indigo-100 hover:bg-indigo-50 px-2.5 py-1.5 rounded-full text-[10px] font-bold transition"
                          >
                            <PlusCircle size={12} />
                            ยังไม่ได้เรียน
                          </button>
                        )}
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>
        );

      case 'designSystem':
        return (
          <div className="space-y-5 animate-fade-in">
            <div className="bg-white p-5 rounded-3xl border border-slate-100 shadow-sm space-y-4">
              <h3 className="text-sm font-bold text-slate-800 flex items-center gap-2">
                <Palette className="text-emerald-500" size={18} />
                Design System ของแอปพลิเคชัน
              </h3>
              
              <div className="space-y-3 text-xs text-slate-600">
                <div>
                  <h4 className="font-bold text-slate-700 mb-1">1. Brand Identity & Colors</h4>
                  <p className="mb-2 text-slate-400">พัฒนาโดยอ้างอิงจากแบรนด์บอร์ด "SENIOR FIT" และสาขาดิจิทัลดีไซน์</p>
                  <div className="grid grid-cols-4 gap-2 text-center text-[10px] font-mono text-white">
                    <div className="bg-emerald-600 p-2 rounded-xl">#059669<br/>Emerald</div>
                    <div className="bg-teal-700 p-2 rounded-xl">#0f766e<br/>Teal</div>
                    <div className="bg-slate-900 p-2 rounded-xl">#0f172a<br/>Slate</div>
                    <div className="bg-slate-100 p-2 rounded-xl text-slate-700">#f1f5f9<br/>Light Gray</div>
                  </div>
                </div>

                <div>
                  <h4 className="font-bold text-slate-700 mb-1">2. Typography</h4>
                  <div className="p-3 bg-slate-50 rounded-2xl border border-slate-100 space-y-1">
                    <p style={{ fontFamily: 'Inter' }} className="font-bold">English: Inter (For Numbers & Interfaces)</p>
                    <p style={{ fontFamily: 'Sarabun' }} className="text-slate-500">ภาษาไทย: สารบรรณ TH Sarabun (เพื่อความสุภาพและเป็นทางการ)</p>
                  </div>
                </div>

                <div>
                  <h4 className="font-bold text-slate-700 mb-1 flex items-center gap-1.5">
                    <Volume2 size={14} className="text-emerald-500" />
                    3. Voice and Tone (น้ำเสียงการสื่อสาร)
                  </h4>
                  <ul className="list-disc pl-4 space-y-1 text-slate-500 text-[11px]">
                    <li><strong className="text-slate-700">Friendly:</strong> ภาษาเข้าใจง่าย เป็นกันเองกับนักศึกษา</li>
                    <li><strong className="text-slate-700">Supportive:</strong> แนะนำและเตือนวิชาที่ยังขาดเพื่อช่วยพัฒนาการเรียน</li>
                    <li><strong className="text-slate-700">Professional:</strong> สวยงาม เรียบร้อย สมกับสาขาออกแบบเทคโนโลยี</li>
                  </ul>
                </div>
              </div>
            </div>

            {/* Profile editing card */}
            <div className="bg-white p-5 rounded-3xl border border-slate-100 shadow-sm">
              <h3 className="text-sm font-bold text-slate-800 mb-4 flex items-center gap-2">
                <User size={18} className="text-emerald-500" />
                ข้อมูลโปรไฟล์นักศึกษา
              </h3>

              <div className="space-y-3">
                <div>
                  <label className="text-[10px] text-slate-400 font-semibold block mb-1">ชื่อ-นามสกุล</label>
                  <input 
                    type="text" 
                    value={profile.name}
                    onChange={(e) => setProfile({ ...profile, name: e.target.value })}
                    className="w-full text-xs p-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-emerald-500"
                  />
                </div>
                <div>
                  <label className="text-[10px] text-slate-400 font-semibold block mb-1">รหัสนักศึกษา</label>
                  <input 
                    type="text" 
                    value={profile.studentId}
                    onChange={(e) => setProfile({ ...profile, studentId: e.target.value })}
                    className="w-full text-xs p-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-emerald-500"
                  />
                </div>
              </div>
            </div>
          </div>
        );

      default:
        return null;
    }
  };

  return (
    <div className="min-h-screen bg-slate-900 py-10 px-4 flex flex-col items-center justify-center font-sans select-none" style={{ fontFamily: 'Sarabun, Inter, sans-serif' }}>
      
      {/* Top Controller Bar - Toggle Device Frame */}
      <div className="mb-6 flex gap-3 z-10">
        <button 
          onClick={() => setIsMobileFrame(true)} 
          className={`px-4 py-2 rounded-full text-xs font-bold transition flex items-center gap-2 shadow-md ${
            isMobileFrame ? 'bg-emerald-600 text-white' : 'bg-slate-800 text-slate-400 hover:text-white'
          }`}
        >
          <Layout size={14} />
          มุมมองมือถือ (Samsung Frame)
        </button>
        <button 
          onClick={() => setIsMobileFrame(false)} 
          className={`px-4 py-2 rounded-full text-xs font-bold transition flex items-center gap-2 shadow-md ${
            !isMobileFrame ? 'bg-emerald-600 text-white' : 'bg-slate-800 text-slate-400 hover:text-white'
          }`}
        >
          <FileText size={14} />
          เต็มจอ (Responsive Website)
        </button>
      </div>

      {/* Main Wrapper Box */}
      <div className={`transition-all duration-300 overflow-hidden ${
        isMobileFrame 
          ? 'w-[375px] h-[812px] bg-slate-950 rounded-[50px] border-[12px] border-slate-800 shadow-2xl relative flex flex-col' 
          : 'w-full max-w-lg min-h-[600px] bg-slate-950 rounded-3xl shadow-xl flex flex-col p-2'
      }`}>
        
        {/* Device Status Bar (Only visible in mobile frame model) */}
        {isMobileFrame && (
          <div className="px-6 pt-3 pb-2 flex justify-between items-center text-white text-[11px] font-medium z-10">
            <span>15:30</span>
            <div className="w-16 h-4 bg-black rounded-full absolute left-1/2 -translate-x-1/2 top-4"></div>
            <div className="flex gap-1">
              <span>📶</span>
              <span>🔋 100%</span>
            </div>
          </div>
        )}

        {/* Inner Mobile App Container */}
        <div className="flex-1 bg-slate-50 flex flex-col overflow-hidden rounded-[38px] relative">
          
          {/* Header Bar */}
          <header className="bg-white border-b border-slate-100 p-4 flex items-center justify-between">
            <div className="flex items-center gap-2">
              <div className="w-9 h-9 rounded-xl bg-gradient-to-tr from-emerald-600 to-teal-500 flex items-center justify-center text-white shadow-md">
                <GraduationCap size={20} />
              </div>
              <div>
                <h2 className="text-xs font-extrabold text-slate-800 leading-tight">DD&T Grade Tracker</h2>
                <p className="text-[9px] text-slate-400">สถาบันเทคโนโลยีดิจิทัล</p>
              </div>
            </div>

            {/* Profile Mini Bubble */}
            <div className="flex items-center gap-2">
              <div className="text-right">
                <p className="text-[10px] font-bold text-slate-700 leading-none">{profile.name}</p>
                <p className="text-[8px] text-slate-400">{profile.studentId}</p>
              </div>
              <img 
                src={profile.avatar} 
                alt="Profile" 
                className="w-7 h-7 rounded-full object-cover border border-slate-200"
              />
            </div>
          </header>

          {/* Tab Content Display Area with Custom Scrollbars */}
          <main className="flex-1 overflow-y-auto px-4 py-4 space-y-4 pb-20 select-none">
            {renderAppContent()}
          </main>

          {/* Bottom Navigation System */}
          <nav className="absolute bottom-0 left-0 right-0 bg-white/90 backdrop-blur-md border-t border-slate-100/80 px-3 py-2 flex justify-around items-center z-10 rounded-b-[38px]">
            {[
              { id: 'dashboard', label: 'ภาพรวม', icon: Layout },
              { id: 'planner', label: 'เกรดรายเทอม', icon: BookOpen },
              { id: 'curriculum', label: 'วิชาบังคับ', icon: CheckCircle },
              { id: 'designSystem', label: 'ตั้งค่า/DS', icon: Settings },
            ].map(tab => {
              const Icon = tab.icon;
              const isActive = activeTab === tab.id;
              return (
                <button
                  key={tab.id}
                  onClick={() => setActiveTab(tab.id)}
                  className={`flex flex-col items-center gap-1 p-1 transition-all ${
                    isActive ? 'text-emerald-600 scale-105 font-bold' : 'text-slate-400 hover:text-slate-600'
                  }`}
                >
                  <Icon size={18} />
                  <span className="text-[9px]">{tab.label}</span>
                </button>
              );
            })}
          </nav>

        </div>
      </div>

      {/* --- ADD / EDIT COURSE MODAL --- */}
      {isAddOpen && (
        <div className="fixed inset-0 bg-slate-900/80 backdrop-blur-sm flex items-center justify-center z-50 p-4">
          <div className="bg-white rounded-3xl w-full max-w-sm p-6 shadow-2xl animate-scale-up">
            <div className="flex justify-between items-center mb-4">
              <h3 className="text-sm font-bold text-slate-800">
                {editingCourse ? 'แก้ไขข้อมูลวิชาเรียน' : 'เพิ่มวิชาเรียนใหม่'}
              </h3>
              <button onClick={() => setIsAddOpen(false)} className="text-slate-400 hover:text-slate-600">
                <X size={18} />
              </button>
            </div>

            <form onSubmit={handleSaveCourse} className="space-y-4">
              <div>
                <label className="text-[10px] text-slate-400 font-bold block mb-1">รหัสวิชา</label>
                <input 
                  type="text" 
                  placeholder="เช่น DDT-201" 
                  value={newCourse.code}
                  onChange={(e) => setNewCourse({ ...newCourse, code: e.target.value })}
                  className="w-full text-xs p-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-emerald-500 uppercase"
                  required
                />
              </div>

              <div>
                <label className="text-[10px] text-slate-400 font-bold block mb-1">ชื่อรายวิชา</label>
                <input 
                  type="text" 
                  placeholder="เช่น การออกแบบประสบการณ์ผู้ใช้" 
                  value={newCourse.name}
                  onChange={(e) => setNewCourse({ ...newCourse, name: e.target.value })}
                  className="w-full text-xs p-2.5 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-emerald-500"
                  required
                />
              </div>

              <div className="grid grid-cols-2 gap-3">
                <div>
                  <label className="text-[10px] text-slate-400 font-bold block mb-1">หน่วยกิต</label>
                  <select 
                    value={newCourse.credits}
                    onChange={(e) => setNewCourse({ ...newCourse, credits: Number(e.target.value) })}
                    className="w-full text-xs p-2.5 rounded-xl border border-slate-200 bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500"
                  >
                    {[1, 2, 3, 4, 6].map(c => <option key={c} value={c}>{c} หน่วยกิต</option>)}
                  </select>
                </div>

                <div>
                  <label className="text-[10px] text-slate-400 font-bold block mb-1">เกรดที่ได้รับ</label>
                  <select 
                    value={newCourse.grade}
                    onChange={(e) => setNewCourse({ ...newCourse, grade: e.target.value })}
                    className="w-full text-xs p-2.5 rounded-xl border border-slate-200 bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500"
                  >
                    {Object.keys(GRADE_POINTS).map(g => <option key={g} value={g}>{g}</option>)}
                  </select>
                </div>
              </div>

              <div className="grid grid-cols-2 gap-3">
                <div>
                  <label className="text-[10px] text-slate-400 font-bold block mb-1">หมวดหมู่วิชา</label>
                  <select 
                    value={newCourse.category}
                    onChange={(e) => setNewCourse({ ...newCourse, category: e.target.value })}
                    className="w-full text-xs p-[9px] rounded-xl border border-slate-200 bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500"
                  >
                    <option value="GE-Thai">ศึกษาทั่วไป - ไทย</option>
                    <option value="GE-English">ศึกษาทั่วไป - อังกฤษ</option>
                    <option value="GE-Sci">ศึกษาทั่วไป - วิทย์</option>
                    <option value="GE-Math">ศึกษาทั่วไป - คณิต</option>
                    <option value="GE-Social">ศึกษาทั่วไป - สังคม</option>
                    <option value="GE-Human">ศึกษาทั่วไป - มนุษย์</option>
                    <option value="Core">วิชาแกนสาขา</option>
                    <option value="Major-Compulsory">วิชาชีพบังคับ</option>
                    <option value="Major-Elective">วิชาชีพเลือก</option>
                    <option value="Free-Elective">วิชาเลือกเสรี</option>
                  </select>
                </div>

                <div>
                  <label className="text-[10px] text-slate-400 font-bold block mb-1">ภาคการศึกษา (เทอม)</label>
                  <select 
                    value={newCourse.term}
                    onChange={(e) => setNewCourse({ ...newCourse, term: e.target.value })}
                    className="w-full text-xs p-2.5 rounded-xl border border-slate-200 bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500"
                  >
                    {terms.map(t => <option key={t} value={t}>เทอม {t}</option>)}
                  </select>
                </div>
              </div>

              <div className="pt-2 flex gap-2">
                <button 
                  type="button" 
                  onClick={() => setIsAddOpen(false)}
                  className="w-1/2 py-2.5 border border-slate-200 text-slate-500 rounded-xl text-xs font-bold hover:bg-slate-50 transition"
                >
                  ยกเลิก
                </button>
                <button 
                  type="submit" 
                  className="w-1/2 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl text-xs font-bold transition shadow-md"
                >
                  {editingCourse ? 'อัปเดตวิชา' : 'เพิ่มลงแผนการเรียน'}
                </button>
              </div>
            </form>
          </div>
        </div>
      )}

      {/* Embedded CSS for animations and custom visual properties */}
      <style>{`
        @keyframes fadeIn {
          from { opacity: 0; transform: translateY(8px); }
          to { opacity: 1; transform: translateY(0); }
        }
        @keyframes scaleUp {
          from { opacity: 0; transform: scale(0.95); }
          to { opacity: 1; transform: scale(1); }
        }
        .animate-fade-in {
          animation: fadeIn 0.35s ease-out forwards;
        }
        .animate-scale-up {
          animation: scaleUp 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
      `}</style>

    </div>
  );
}
